  <footer>
    <div class="container">
      <span id="footer-name">Kate Nagele</span> - Instructional Designer
    </div>
  </footer>

  <script>
    // Load projects from projects.json and render cards
    async function loadProjects() {
      const grid = document.getElementById('project-grid');
      const countEl = document.getElementById('project-count');

      try {
        const res = await fetch('projects.json');
        if (!res.ok) throw new Error('Could not load projects.json');
        const projects = await res.json();

        countEl.textContent = `${projects.length} project${projects.length !== 1 ? 's' : ''}`;

        grid.innerHTML = projects.map(p => `
          <a class="project-card" href="project.html?id=${encodeURIComponent(p.id)}">
            <div class="project-card-thumb">
              ${p.thumbnail
                ? `<img src="${p.thumbnail}" alt="${p.title}" onerror="this.parentElement.innerHTML=thumbPlaceholder()" />`
                : thumbPlaceholderHTML()
              }
            </div>
            <div class="project-card-body">
              <div class="project-card-title">${p.title}</div>
              <div class="project-card-desc">${p.description}</div>
              <div class="project-card-meta">
                ${p.duration ? `<span>
                  <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/>
                  </svg>
                  ${p.duration}
                </span>` : ''}
                ${p.tools ? `<span>${p.tools}</span>` : ''}
              </div>
              <div class="project-tags">
                ${(p.tags || []).map(t => `<span class="tag">${t}</span>`).join('')}
              </div>
            </div>
          </a>
        `).join('');
      } catch (e) {
        grid.innerHTML = `<div class="error-msg"><p>Could not load projects. Make sure you're running this on a web server.</p></div>`;
        console.error(e);
      }
    }

    function thumbPlaceholderHTML() {
      return `<div class="thumb-placeholder">
        <svg width="48" height="48" fill="none" stroke="#2d6a9f" stroke-width="1.5" viewBox="0 0 24 24">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <path d="M8 21h8M12 17v4"/>
          <polygon points="10,8 16,11 10,14"/>
        </svg>
      </div>`;
    }

    loadProjects();
  </script>
</body>
</html>
